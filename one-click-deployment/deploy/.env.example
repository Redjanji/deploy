# =====================================================
# XSS 微服务集群 - 环境变量配置
# =====================================================
# 使用方式：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 检查以下配置项（已预置强密码，生产环境可按需再改）
#   3. 执行 docker compose up -d
# =====================================================
# 注意：MAIL_PASSWORD 为 QQ 邮箱授权码，需用户自行在
#       QQ 邮箱设置中获取，不能随机生成。
# 密码仅含字母、数字、下划线，避免 shell 特殊字符问题。
# =====================================================

# ---------------------------------------------------
# MySQL 配置
# ---------------------------------------------------
MYSQL_ROOT_PASSWORD=XssMysql2026Sec9fKp3mZq7v
MYSQL_PORT=3306

# ---------------------------------------------------
# Redis 配置
# ---------------------------------------------------
REDIS_PASSWORD=XssRedis2026Sec7vNt2wLp4h
REDIS_PORT=6379

# ---------------------------------------------------
# RabbitMQ 配置
# ---------------------------------------------------
RABBITMQ_USER=xss_admin
RABBITMQ_PASS=XssRabbit2026Sec4hJm8cBq6k
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---------------------------------------------------
# Elasticsearch 配置
# ---------------------------------------------------
ES_PORT=9200

# ---------------------------------------------------
# MinIO 配置
# ---------------------------------------------------
MINIO_ACCESS_KEY=xssAdmin2026Key
MINIO_SECRET_KEY=XssMinio2026Sec6kQr9wYt5nBz
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------
# Nacos 配置
# Base64 编码，长度 >= 48 字符
# 重新生成：openssl rand -base64 48
# ---------------------------------------------------
NACOS_PORT=8848
NACOS_AUTH_TOKEN=SGVsbG9OYWNIb3N0U2VjcmV0S2V5Rm9yQXV0aDIwMjZYc3NQbGF0Zm9ybQ==
NACOS_AUTH_IDENTITY_KEY=xssNacosAuthKey2026
NACOS_AUTH_IDENTITY_VALUE=XssNacos2026SecIdentityValue8x

# ---------------------------------------------------
# JWT 密钥（auth-service 和 gateway-service 共用）
# Base64 编码，256-bit
# 重新生成：openssl rand -base64 32
# ---------------------------------------------------
JWT_SECRET=eW91ci0yNTYtYml0LXNlY3JldC1rZXktZm9yLWp3dC1zaWduaW5nLWFuZC1wcm9kdWN0aW9uLW9ubHktMjAyNg==

# ---------------------------------------------------
# 应用凭证密钥（用于服务间 HMAC 签名认证）
# ---------------------------------------------------
APP_SECRET_BACKEND=XssBackend2026SecHmacKey8xYz
APP_SECRET_DASHBOARD=XssDashboard2026SecHmacKey3pQw

# ---------------------------------------------------
# 邮件配置（message-service 使用）
# MAIL_PASSWORD 为 QQ 邮箱 SMTP 授权码，须在 QQ 邮箱
# 「设置 → 账户 → POP3/SMTP 服务」中开启并获取
# ---------------------------------------------------
MAIL_USERNAME=753280878@qq.com
MAIL_PASSWORD=ufhravxbjladbeig

# ---------------------------------------------------
# 审核服务内部 Token
# ---------------------------------------------------
REVIEW_INTERNAL_TOKEN=XssReview2026SecInternalToken7mKz9p

# ---------------------------------------------------
# 消息通知管理员邮箱
# ---------------------------------------------------
MESSAGE_NOTIFY_ADMIN_EMAIL=redjanji@163.com
