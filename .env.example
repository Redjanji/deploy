# =====================================================
# XSS 微服务集群 - 环境变量配置示例
# =====================================================
# 使用方法：
#   开发环境：只需设置 JWT_SECRET（其余变量有指向 WSL 的默认值）
#   生产环境：将所有变量改为生产值，通过系统环境变量或 -D 参数注入
#   [必须] 标记的变量无默认值，不设置将导致认证功能不可用
# =====================================================

# ---------- MySQL 数据库（6 个服务共用同一实例，各用独立 database） ----------
MYSQL_HOST=172.24.35.23
MYSQL_USER=root
MYSQL_PASS=root

# ---------- Redis ----------
REDIS_HOST=172.24.35.23
REDIS_PASSWORD=redisroot

# ---------- RabbitMQ ----------
RABBITMQ_HOST=172.24.35.23
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ---------- MinIO（image-service） ----------
MINIO_ENDPOINT=http://172.24.35.23:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---------- SMTP 邮件（message-service） ----------
# QQ 邮箱 SMTP 授权码（非登录密码），在 QQ邮箱设置 > 账户 > POP3/SMTP 中生成
MAIL_USERNAME=753280878@qq.com
MAIL_PASSWORD=ufhravxbjladbeig

# ---------- Elasticsearch（search-service） ----------
ES_URIS=http://172.24.35.23:9200

# ---------- JWT 签名密钥 [必须] ----------
# Base64 编码，至少 32 字节（256 位）
# 生成方法：openssl rand -base64 32
# gateway-service 和 auth-service 必须使用相同值，否则 Token 验签失败
JWT_SECRET=

# ---------- 应用凭证 [必须] ----------
# 网关 /token 接口的应用密钥，使用强随机字符串
# 生成方法：openssl rand -hex 32
APP_SECRET_BACKEND=
APP_SECRET_DASHBOARD=

# ---------- 网关 IP 白名单配置 ----------
# 是否启用 IP 白名单，生产环境建议设为 true
IP_WHITELIST_ENABLED=false
# 允许的 IP 列表，用逗号分隔，支持单个 IP 或 CIDR 格式
IP_ALLOWED_IPS=127.0.0.1,::1,192.168.1.0/24

# ---------- Nacos 配置 ----------
# Nacos Server 地址（服务注册发现 + 配置中心）
NACOS_SERVER_ADDR=127.0.0.1:8848
# Nacos 命名空间，生产环境建议按环境划分（dev/test/prod）
NACOS_NAMESPACE=public

# ---------- 下游服务地址（网关路由 + 服务间调用） ----------
# 已接入 Nacos 服务发现，使用服务名即可，Nacos 会自动解析为实际 IP:端口
# 格式：http://<service-name>
SERVICE_DICT=http://dict-service
SERVICE_IMAGE=http://image-service
SERVICE_AUTH=http://auth-service
SERVICE_PROPERTY=http://property-service
SERVICE_SEARCH=http://search-service
SERVICE_ANALYTICS=http://analytics-service
SERVICE_MESSAGE=http://message-service

# ---------- 可选配置 ----------
# 图片 CDN 地址（留空则使用本地路径通过网关转发）
IMAGE_CDN_URL=
# 消息通知管理员邮箱（property-service 审核通知收件人）
MESSAGE_NOTIFY_ADMIN_EMAIL=redjanji@163.com
